        - 30f1ff6f-1cc8-4a32-b07f-707f71e7c73d
        description: "\u043A\u043E\u0433\u0434\u0430 \u0440\u0435\u0448\u0438\u043B\u0438
          \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0443, \u0443\u0431\u0438\u0440\u0430\u0435\u043C
          \u0431\u0430\u0440\u044C\u0435\u0440\u044B, \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u043C
          \u0442\u0440\u0438\u0433\u0433\u0435\u0440 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0430,
          \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043C \u043A \u043D\u0430\u043C
          \u043D\u043F\u0441, \u043E\u0431\u043D\u043E\u0432\u043B\u044F\u0435\u043C
          \u0441\u043F\u043B\u0430\u0439\u043D\u044B"
