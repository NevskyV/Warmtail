    - rid: 6510803699832980028
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: fed43af1-96c5-4539-a2f0-bd75daf508e4
        NextNodeIds:
        - c7ffe548-36db-4865-9dfc-85376421755d
        Text: "\u0420\u043E\u0434\u0438\u043B\u0441\u044F \u044F \u043D\u0435 \u0437\u0434\u0435\u0441\u044C,
          \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980029
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: c7ffe548-36db-4865-9dfc-85376421755d
        NextNodeIds:
        - 4c2fabc7-19b6-49ed-a1e2-337c12c60466
        Text: "\u0422\u043E\u0433\u0434\u0430 \u0435\u0449\u0451 \u0431\u044B\u043B\u043E
          \u0442\u0435\u043F\u043B\u043E, \u043C\u044B \u0441\u043E \u0432\u0441\u0435\u0439
          \u0441\u0435\u043C\u044C\u0435\u0439 \u043F\u043B\u0430\u0432\u0430\u043B\u0438
          \u0442\u0430\u043C."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980030
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 4c2fabc7-19b6-49ed-a1e2-337c12c60466
        NextNodeIds:
        - 6d2fec65-0b4e-4a3e-a5d7-8f285aa0df99
        Text: "\u041E-\u043E-\u043E, \u044D\u0442\u043E \u043C\u0438\u043B\u043E."
        Character: 0
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980031
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 6d2fec65-0b4e-4a3e-a5d7-8f285aa0df99
        NextNodeIds:
        - 0877f7dd-544a-432a-9cc4-6696c0eff774
        Text: "\u041D\u043E \u043C\u044B, \u0447\u0435\u0440\u0435\u043F\u0430\u0445\u0438,
          \u0434\u043E\u043B\u0433\u043E \u0436\u0438\u0432\u0451\u043C, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
          \u044F \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043E\u0431\u0449\u0430\u044E\u0441\u044C
          \u0441\u043E \u0441\u0432\u043E\u0438\u043C \u0434\u0435\u0434\u0443\u0448\u043A\u043E\u0439!"
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980032
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 0877f7dd-544a-432a-9cc4-6696c0eff774
        NextNodeIds:
        - 552d5d9e-309f-49aa-939a-355230b169ca
        Text: "\u0410 \u0443 \u043C\u0435\u043D\u044F \u0432\u0435\u0434\u044C \u0443\u0436\u0435
          \u0432\u043D\u0443\u043A\u0438 \u0435\u0441\u0442\u044C, \u0445\u0430-\u0445\u0430-\u0445\u0430!"
        Character: 1
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980033
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 552d5d9e-309f-49aa-939a-355230b169ca
        NextNodeIds:
        - b955ec06-dd93-4b33-851c-e7625cd8de34
        Text: "\u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
          \u0441\u0435\u0439\u0447\u0430\u0441 \u044F \u043E\u0441\u043E\u0437\u043D\u0430\u044E,
          \u0447\u0442\u043E \u0432\u0441\u0451 \u043D\u0435 \u0442\u0430\u043A \u043F\u043B\u043E\u0445\u043E."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980034
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: b955ec06-dd93-4b33-851c-e7625cd8de34
        NextNodeIds:
        - d0742a57-4d37-4e33-9cfc-8bb7f62eaeaf
        Text: "\u0418 \u0445\u043E\u043B\u043E\u0434 \u043C\u044B \u0432\u043C\u0435\u0441\u0442\u0435
          \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0436\u0438\u0442\u0435\u043B\u044F\u043C\u0438
          \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u0435\u043C."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980035
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: d0742a57-4d37-4e33-9cfc-8bb7f62eaeaf
        NextNodeIds:
        - 027b86fc-623a-4cac-9288-d2d9267b566d
        Text: "\u0410 \u0437\u0430 \u0442\u0435\u0431\u044F \u044F \u0442\u043E \u0442\u0435\u043C
          \u0431\u043E\u043B\u0435\u0435 \u043D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u044E!
          \u0422\u044B \u0448\u0443\u0441\u0442\u0440\u044B\u0439 \u0438 \u0443\u043C\u0435\u0435\u0448\u044C
          \u0441\u043E\u0433\u0440\u0435\u0432\u0430\u0442\u044C."
        Character: 1
        Emotion: 0
        DisplayName: 
