        NextNodeIds:
        - d087df04-537c-41b9-8ce3-65d4c1611adb
        Text: "\u0414\u0430, \u044D\u0442\u043E \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
          \u0442\u043E\u043C\u0443 \u043E\u0441\u043A\u043E\u043B\u043A\u0443."
        Character: 0
        Emotion: 1
        DisplayName: 
    - rid: 4719408681517580384
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: d087df04-537c-41b9-8ce3-65d4c1611adb
        NextNodeIds:
        - c610c3da-f774-4f9c-91e2-e2985ba978bb
        Text: "\u0421\u043A\u0430\u0436\u0438, \u0434\u0438\u0442\u044F, \u0442\u044B
