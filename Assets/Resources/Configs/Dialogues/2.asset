        - 4d309543-673c-4dcf-8147-ef4ae1a921de
        Text: "\u0420\u0430\u0437 \u0442\u044B \u0442\u0443\u0442 \u0432\u043F\u0435\u0440\u0432\u044B\u0435,
          \u0442\u043E \u044F \u0442\u0435\u0431\u0435 \u0432\u0441\u0451 \u043F\u043E\u043A\u0430\u0436\u0443."
