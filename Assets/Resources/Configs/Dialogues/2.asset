        NextNodeIds:
        - 4635c582-d303-4030-96bb-c563c9a2b84e
        Text: "\u0410 \u043A\u0430\u043A \u0432\u044B \u043F\u043E\u043D\u044F\u043B\u0438,
          \u0447\u0442\u043E \u044F \u043D\u0435 \u043E\u0442\u0441\u044E\u0434\u0430?"
        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 4061568565155201318
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 4635c582-d303-4030-96bb-c563c9a2b84e
        NextNodeIds:
        - 77b62e8b-15a2-4f37-bf5d-97166790f587
        Text: "\u042F \u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B
