        NextNodeIds:
        - 5322c258-c235-43ad-b595-b3e5cbdf2206
        Text: "\u042D\u0445, \u0447\u0442\u043E \u0436\u0435 \u0442\u044B \u0442\u0430\u043A\u043E\u0439
