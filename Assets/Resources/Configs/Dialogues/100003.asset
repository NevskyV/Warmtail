          \u0432 \u0441\u0435\u0440\u0434\u0446\u0435 \u0441\u0442\u0430\u0442\u0443\u0438
          \u0438 \u0440\u0435\u0448\u0438\u043B \u0435\u0433\u043E \u0437\u0430\u0431\u0440\u0430\u0442\u044C."
        Character: 7
        Emotion: 0
        DisplayName: 
