        NextNodeIds:
        - 11bbfc57-eeb7-473c-b268-3d0f2c1b3073
        Text: "\u0425\u043C, \u0434\u0430\u0432\u0430\u0439 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C,
          \u0447\u0442\u043E \u043D\u0430\u043C \u044D\u0442\u043E \u0434\u0430\u043B\u043E."
        Character: 7
        Emotion: 6
        DisplayName: 
    - rid: 6510803690743661139
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 11bbfc57-eeb7-473c-b268-3d0f2c1b3073
        NextNodeIds:
        - 71c1ad68-f252-4488-bd07-8ed603a583e4
        Text: "\u042F \u0443\u0432\u0438\u0434\u0435\u043B \u044D\u0442\u043E\u0442
