        NextNodeIds:
        - b0ef79ee-ee38-4dc2-98bd-c9a58ef08c89
        Text: "\u042F \u0441\u0435\u0431\u0435 \u0442\u043E\u0436\u0435 \u043D\u0435\u043C\u043D\u043E\u0433\u043E
