        Text: "\u041C\u043E\u043B\u043E\u0434\u0435\u0446, {playerName}, \u0442\u0435\u043F\u0435\u0440\u044C
          \u0432\u0441\u0435 \u043E\u043D\u0438 \u0441\u043D\u043E\u0432\u0430 \u0430\u043A\u0442\u0438\u0432\u043D\u044B."
