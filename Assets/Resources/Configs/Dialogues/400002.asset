        - d1fd8268-f2cb-4c04-a9c2-048f6ce5e78c
        Text: "{playerName}, \u043F\u0440\u0438\u0432\u0435\u0442, \u0435\u0441\u0442\u044C
          \u0434\u0435\u043B\u044C\u0446\u0435."
        Character: 2
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980047
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: d1fd8268-f2cb-4c04-a9c2-048f6ce5e78c
        NextNodeIds:
        - e6420d3f-42e7-4444-80dd-1d20dfdb1b53
        Text: "\u041E\u0433\u043E! \u0422\u0430\u043A \u0441\u0440\u0430\u0437\u0443?"
        Character: 0
        Emotion: 3
        DisplayName: 
    - rid: 6510803699832980048
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: e6420d3f-42e7-4444-80dd-1d20dfdb1b53
        NextNodeIds:
        - 9b6423b2-6658-4e29-b089-e52186c3af2f
        Text: "\u0414\u0430, \u044F \u0432\u044B\u0437\u0432\u0430\u043B\u0430\u0441\u044C
          \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044C
          \u0432\u0438\u0434\u043E\u0432 \u043D\u0430 \u0434\u043D\u0435."
        Character: 2
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980049
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 9b6423b2-6658-4e29-b089-e52186c3af2f
        NextNodeIds:
        - 7160f78e-83d5-42f8-b3d4-eab52df2d495
        Text: "\u0422\u0430\u043A \u043A\u0430\u043A \u0443 \u043C\u0435\u043D\u044F
          \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C \u0431\u043E\u043B\u0435\u0435
          \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u0430\u044F
          \u0437\u0430\u0434\u0430\u0447\u0430 \u0432\u0432\u0438\u0434\u0435 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
          \u043F\u0440\u0438\u0437\u043C\u044B, \u0442\u043E \u044F \u0445\u043E\u0447\u0443
          \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u0442\u044C \u0442\u0435\u0431\u044F
          \u043E \u043F\u043E\u043C\u043E\u0449\u0438."
        Character: 2
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980050
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 7160f78e-83d5-42f8-b3d4-eab52df2d495
        NextNodeIds:
        - d6966418-8846-47c3-a40e-63b0062a1d72
        Text: "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
          \u0432 \u044D\u0442\u0443 \u043A\u043D\u0438\u0433\u0443 \u0432\u0438\u0434\u044B
          \u0432\u0441\u0435\u0445 \u0441\u0443\u0449\u0435\u0441\u0442\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
          \u0432\u0441\u0442\u0440\u0435\u0442\u044F\u0442\u0441\u044F \u0442\u0435\u0431\u0435
          \u0432 \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0438?"
        Character: 2
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980051
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: d6966418-8846-47c3-a40e-63b0062a1d72
        NextNodeIds:
        - fe79bc5f-e933-40a8-8963-88e332c26b23
        Text: "\u0414\u0443\u043C\u0430\u044E \u0434\u0430!"
        Character: 0
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980052
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: d4434a0b-a252-4752-a450-d70605662234
        NextNodeIds:
        - 619d83fc-298d-4750-93a8-d5f1f0901151
        Text: "\u041D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439,
          \u044F \u0442\u0435\u0431\u0435 \u043E\u0442\u0434\u0430\u043C \u043D\u043E\u0432\u043E\u0433\u043E
          \u043C\u0438\u043B\u0430\u0448\u043D\u043E\u0433\u043E \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430! "
        Character: 2
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980053
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: fe79bc5f-e933-40a8-8963-88e332c26b23
        NextNodeIds:
        - 0e8a403b-ef3c-4334-abac-a5d51f54dbe9
        Text: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0435!
          \u0422\u044B \u0441\u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043B \u043C\u043D\u0435
          \u043A\u0443\u0447\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
        Character: 2
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980054
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 0e8a403b-ef3c-4334-abac-a5d51f54dbe9
        NextNodeIds:
        - d4434a0b-a252-4752-a450-d70605662234
        Text: "\u041A\u043E\u0433\u0434\u0430 \u0437\u0430\u043F\u0438\u0448\u0435\u0448\u044C
          \u0432\u0441\u0435 \u0432\u0438\u0434\u044B, \u043F\u0440\u0438\u0445\u043E\u0434\u0438
          \u043A\u043E \u043C\u043D\u0435!"
        Character: 2
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980055
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
