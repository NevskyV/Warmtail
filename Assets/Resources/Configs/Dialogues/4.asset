        NextNodeIds:
        - e5c3a2d2-f2e9-4e0d-bbb2-9fd5889fcb8b
        Text: "\u0414\u043E\u043C \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0439,
          \u043D\u043E \u043F\u0443\u0441\u0442\u043E\u0432\u0430\u0442."
        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 6510803294068408593
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: e5c3a2d2-f2e9-4e0d-bbb2-9fd5889fcb8b
        NextNodeIds:
        - c67041cb-185f-42ec-8755-7d2ca627a044
        Text: "\u0417\u043D\u0430\u044E, \u0434\u0438\u0442\u044F. \u042F \u0442\u0435\u0431\u0435
          \u0443\u0436\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
          \u043F\u0440\u043E \u0442\u043E, \u0447\u0442\u043E \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
          \u043F\u043E\u043A\u0443\u043F\u0430\u0442\u044C \u0434\u0435\u043A\u043E\u0440\u0430\u0446\u0438\u0438
