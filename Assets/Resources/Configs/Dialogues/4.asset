      data:
        NodeId: 57c966b3-c6f1-4bf7-87e3-0ed1c0d30c35
        NextNodeIds:
        - e46d4306-0eba-47b1-adf4-e244e80eaf7a
        Text: "\u0414\u0430 \u043D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439
          \u0442\u044B, \u0442\u0443\u0442 \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E
