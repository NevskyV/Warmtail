        - 85b6e3c5-6064-4d9f-a142-7f6f87f5af9f
        Text: "\u041E\u043D \u0442\u0430\u043A\u043E\u0439 \u0431\u043E\u043B\u044C\u0448\u043E\u0439."
        Character: 0
        Emotion: 3
        DisplayName: 
    - rid: 4061568565155201357
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 85b6e3c5-6064-4d9f-a142-7f6f87f5af9f
        NextNodeIds:
        - eafe7af4-00c6-4522-b66a-d53d7477d062
        Text: "\u042D\u0442\u043E \u0435\u0449\u0451 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439,
          \u0443 \u043D\u0430\u0441 \u0442\u0443\u0442 \u0432 <link=hlight>\u0411\u043E\u043B\u044C\u0448\u043E\u043C
          \u0420\u0438\u0444\u0435</link> \u0435\u0441\u0442\u044C \u043C\u043D\u043E\u0433\u043E
          \u0440\u0430\u0437\u043D\u044B\u0445 \u0434\u043E\u043C\u043E\u0432."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 4061568565155201358
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: eafe7af4-00c6-4522-b66a-d53d7477d062
        NextNodeIds:
        - 16fe457f-1e87-4801-a0c2-5c07a93a85af
        Text: "\u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u0420\u0438\u0444... \u0432\u043E\u0442
          \u043A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
          \u044D\u0442\u043E \u043C\u0435\u0441\u0442\u043E."
        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 4061568565155201359
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 80272146-e17d-48f8-aa7b-74f2ab83c3c7
        NextNodeIds:
        - 0d8142d3-fd46-4b04-a6dc-75eaee5b2d6e
        Text: "{playerName}, \u044F \u0441\u043C\u043E\u0442\u0440\u044E, \u0443
          \u0442\u0435\u0431\u044F \u0443\u0436\u0435 \u0435\u0441\u0442\u044C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B."
        Character: 1
        Emotion: 0
        DisplayName: 
