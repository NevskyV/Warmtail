        NextNodeIds:
        - e2b9b988-777f-4698-9b64-b1b8f4d2fd08
        Text: "\u0410 \u043C\u043D\u0435 \u043F\u043E\u0440\u0430 \u0431\u0435\u0436\u0430\u0442\u044C,
          \u0434\u043E \u0441\u043A\u043E\u0440\u044B\u0445 \u0432\u0441\u0442\u0440\u0435\u0447,
          \u0445\u043E-\u0445\u043E-\u0445\u043E!"
        Character: 1
        Emotion: 1
        DisplayName: 
