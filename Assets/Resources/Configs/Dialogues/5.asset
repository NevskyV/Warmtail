        - 8c273152-e126-4b30-a8d4-fe7aec18aa4b
        Text: "\u041E\u043D \u0442\u0430\u043A\u043E\u0439 \u0431\u043E\u043B\u044C\u0448\u043E\u0439."
        Character: 0
        Emotion: 3
