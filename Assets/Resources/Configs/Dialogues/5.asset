        NodeId: 8c273152-e126-4b30-a8d4-fe7aec18aa4b
        NextNodeIds:
        - 9324a748-2769-4e61-9052-0fbe3977ffc1
        Text: "\u042D\u0442\u043E \u0435\u0449\u0451 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439,
          \u0443 \u043D\u0430\u0441 \u0442\u0443\u0442 \u0432 <link=hlight>\u0411\u043E\u043B\u044C\u0448\u043E\u043C
          \u0420\u0438\u0444\u0435</link> \u0435\u0441\u0442\u044C \u043C\u043D\u043E\u0433\u043E
          \u0440\u0430\u0437\u043D\u044B\u0445 \u0434\u043E\u043C\u043E\u0432."
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 1003
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 9324a748-2769-4e61-9052-0fbe3977ffc1
        NextNodeIds:
        - 76c289d4-74a5-4860-9497-fccf7f9379f7
        Text: "\u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u0420\u0438\u0444... \u0432\u043E\u0442
          \u043A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
          \u044D\u0442\u043E \u043C\u0435\u0441\u0442\u043E."
        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 1004
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 0a4aaca7-8371-4e07-802d-245d91f6fd65
        NextNodeIds:
        - eb335ba0-1e70-4fbb-8a60-1eb2456d00c5
        Text: "{playerName}, \u044F \u0441\u043C\u043E\u0442\u0440\u044E, \u0443
