      data:
        NodeId: 946fbe0e-6aa2-45cd-a5e7-4773ae1e3b37
        NextNodeIds:
        - 0d8142d3-fd46-4b04-a6dc-75eaee5b2d6e
        Text: "\u041E\u0433\u043E, \u0441\u043F\u0430\u0441\u0438\u0431\u043E!"
        Character: 0
        Emotion: 3
        DisplayName: 
    - rid: 4061568565155201365
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: b51cee47-8207-4fef-86cd-2591cd22a04c
        NextNodeIds:
        - e9266b21-f2e0-411f-82bc-25b8dc6fc766
        Text: "\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439, \u044F \u0443\u0432\u0435\u0440\u0435\u043D
          \u0443 \u0442\u0435\u0431\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F
          \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0435\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
          \u0443\u044E\u0442\u043D\u044B\u043C!"
        Character: 1
        Emotion: 1
        DisplayName: 
    - rid: 4061568565155201366
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
