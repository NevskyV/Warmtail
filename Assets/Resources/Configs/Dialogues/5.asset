        NextNodeIds:
        - 4bf8a054-5b8f-48f7-a724-d72015ec3135
        Text: "{playerName}, \u0434\u0435\u0440\u0436\u0438 \u043E\u0442 \u043C\u0435\u043D\u044F
          \u043F\u043E\u0434\u0430\u0440\u043E\u043A!"
        Character: 1
        Emotion: 1
        DisplayName: 
    - rid: 4061568565155201362
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 0d8142d3-fd46-4b04-a6dc-75eaee5b2d6e
        NextNodeIds:
        - b51cee47-8207-4fef-86cd-2591cd22a04c
        Text: "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
          \u0442\u0430\u043A\u0438\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B
          \u0434\u043B\u044F \u0434\u0435\u043A\u043E\u0440\u0430\u0446\u0438\u0438
          \u0434\u043E\u043C\u0430!"
        Character: 1
        Emotion: 0
        DisplayName: 
    - rid: 4061568565155201363
      type: {class: ActionNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 4bf8a054-5b8f-48f7-a724-d72015ec3135
