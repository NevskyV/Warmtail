        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 1004
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 6c018970-c99e-4652-950b-3fe1ef8909e8
        NextNodeIds:
        - 2c906ad2-8924-4861-a099-f57433638b2f
        Text: "{playerName}, \u044F \u0441\u043C\u043E\u0442\u0440\u044E, \u0443
