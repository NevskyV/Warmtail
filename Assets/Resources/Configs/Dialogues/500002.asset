      data:
        NodeId: 0df49b68-1d3c-44d2-aad2-2c22f5bf62fc
        NextNodeIds:
        - 2dcdde29-021a-4044-8d07-4390fdc4ea10
        Text: "\u0412\u0440\u043E\u0434\u0435 \u0434\u0430, \u0430 \u0442\u044B \u043A\u0442\u043E?"
