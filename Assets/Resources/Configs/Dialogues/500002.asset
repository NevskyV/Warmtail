        - 65bcc322-aa55-4a8a-8201-03ab10cdd7ff
        Text: "\u042F \u0443\u0432\u0435\u0440\u0435\u043D, \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C
          \u043D\u0430\u0439\u0442\u0438 \u0442\u0435\u0445, \u043A\u043E\u043C\u0443
