        Character: 9
        Emotion: 5
        DisplayName: 
    - rid: 6510803699832980078
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 958b0fd3-d444-4b51-8fbe-5629952578dc
        NextNodeIds:
        - 874c2e5a-6b95-4a45-839e-bdecc031bf8c
        Text: "\u041D\u0443 \u0437\u043D\u0430\u0447\u0438\u0442 \u043D\u0430\u0447\u0430\u043B\u043E
          \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043E!"
        Character: 0
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980079
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 874c2e5a-6b95-4a45-839e-bdecc031bf8c
        NextNodeIds:
        - f2f103dc-6311-45ea-99f5-2c5ddd8efbc3
        Text: "\u042F \u0443\u0432\u0438\u0434\u0435\u043B \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u043D\u044B\u0439
          \u043F\u043E\u0440\u0442\u0430\u043B \u0438 \u043F\u043E\u0434\u0443\u043C\u0430\u043B,
          \u0447\u0442\u043E \u043C\u043D\u0435 \u0441\u0442\u043E\u0438\u0442 \u043F\u043E\u043C\u043E\u0447\u044C."
        Character: 0
        Emotion: 0
        DisplayName: 
    - rid: 6510803699832980080
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: f2f103dc-6311-45ea-99f5-2c5ddd8efbc3
        NextNodeIds:
        - 54289044-5e03-43ac-b4eb-6d74712e4137
        Text: "\u0414\u0443\u043C\u0430\u044E, \u0442\u0435\u0431\u0435 \u0441\u0442\u043E\u0438\u0442
          \u0437\u0430\u044F\u0432\u0438\u0442\u044C \u043E \u0441\u0435\u0431\u0435
          \u0438 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C \u0441\u0432\u043E\u0439
          \u0441\u0442\u0438\u0445 \u0432\u0441\u0435\u043C."
        Character: 0
        Emotion: 1
        DisplayName: 
    - rid: 6510803699832980081
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
