        Character: 8
        Emotion: 1
        DisplayName: 
    - rid: 6510803893463285989
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: f2468a6f-4c99-4a2b-ada1-4c6199b4b64f
        NextNodeIds:
        - 68b54d02-c71d-49b4-b587-0095892131f0
        Text: "\u041C\u043D\u043E\u0433\u043E \u0432\u043E\u0434\u044B \u0443\u0442\u0435\u043A\u043B\u043E
          \u0441 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438..."
        Character: 8
        Emotion: 0
        DisplayName: 
    - rid: 6510803893463285990
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: 68b54d02-c71d-49b4-b587-0095892131f0
        NextNodeIds:
        - bb460b6d-4ba5-4db8-8094-e3d00206de00
        Text: "\u041E\u043D \u0441\u0442\u0430\u043B \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u043E\u0439
          \u0420\u0438\u0444\u0430, \u044F \u2013 \u0431\u0440\u043E\u0434\u044F\u0447\u0438\u043C
          \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C."
        Character: 8
        Emotion: 0
        DisplayName: 
    - rid: 6510803893463285991
      type: {class: TextNode, ns: Data.Nodes, asm: Assembly-CSharp}
      data:
        NodeId: bb460b6d-4ba5-4db8-8094-e3d00206de00
        NextNodeIds:
        - b28d5274-2f49-4045-8dbc-5ba2fa28a643
        Text: "\u041D\u043E \u043C\u044B \u0432\u0441\u0451 \u0435\u0449\u0435 \u0438\u043D\u043E\u0433\u0434\u0430
