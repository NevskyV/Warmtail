  m_text: "\u041A\u043E\u043C\u0430\u043D\u0434\u0430\n\n\u2022 \u0412\u0430\u043B\u044F
    \u2014 \u0442\u0438\u043C\u043B\u0438\u0434, \u0442\u0435\u0445\u043B\u0438\u0434,
    \u0433\u0435\u0439\u043C\u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440, \u0441\u0446\u0435\u043D\u0430\u0440\u0438\u0441\u0442,
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A
    \n\u2022 \u0422\u0438\u043C\u0443\u0440 \u2014 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442\n\u2022
    \u0418\u0440\u0430 \u2014 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442\n\u2022
    \u0414\u0438\u0430\u043D\u0430 \u2014 2D \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A"
