  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u0438\u0433\u0440\u0443!\n\n\u041C\u044B
    \u0432\u043B\u043E\u0436\u0438\u043B\u0438 \u043C\u043D\u043E\u0433\u043E \u0441\u0438\u043B
    \u0432 \u044D\u0442\u043E\u0442 \u043F\u0440\u043E\u0435\u043A\u0442 \u0438 \u043D\u0430\u0434\u0435\u0435\u043C\u0441\u044F
    \u043D\u0430 \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0435
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435.\n\n\u0411\u0435\u0437 \u0432\u0430\u0441
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u043D\u0438 \u044D\u0442\u043E\u0439
    \u0438\u0433\u0440\u044B, \u043D\u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043D\u0430\u0441 \u0441\u0430\u043C\u0438\u0445 \u043A\u0430\u043A \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0435\u0439.\n\n\u0412\u044B
    \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
    \u0438\u0433\u0440\u0430\u0442\u044C, \u0442\u0430\u043A \u043A\u0430\u043A \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0430 \u044D\u0442\u043E\u043C \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F!\n\n\u0418
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u043D\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u0432\u0430\u0439\u0442\u0435
    \u0441\u0438\u044F\u0442\u044C!"
